# This repo is developed on Windows with core.autocrlf=true. Git only avoids
# mangling binary files because of its NUL-byte heuristic — don't rely on that.
#
# A compiled gettext catalogue contains CR bytes. If it were ever treated as
# text, CRLF conversion would corrupt it and WordPress would silently fall back
# to the untranslated msgid, with no error anywhere.
*.mo binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.sqlite binary

# Translation sources are text; keep them LF so diffs stay readable and Poedit
# does not rewrite every line on Windows.
*.po  text eol=lf
*.pot text eol=lf
