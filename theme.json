					"name": "Inter (Sans)"
				},
				{
					"fontFamily": "\"Space Grotesk\", system-ui, sans-serif",
					"slug": "display",
					"name": "Space Grotesk (Display)"
				},
				{
					"fontFamily": "\"JetBrains Mono\", monospace",
					"slug": "mono",
					"name": "JetBrains Mono (Mono)"
				}
			]
		}
	}
